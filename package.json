{
  "name": "terrainx",
  "version": "0.1.1",
  "description": "Reusable React map component library powered by MapLibre and OpenFreeMap",
  "author": "Saksham Sahgal",
  "keywords": [
    "map",
    "react",
    "maplibre",
    "openstreetmap",
    "markers",
    "geojson"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sakshamsahgal/TerrainX"
  },
  "type": "module",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "NOTICE",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "maplibre-gl": ">=4.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "maplibre-gl": "^5.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0"
  }
}
